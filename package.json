{
  "name": "folio",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Open-source, self-hostable, attribution-native link-in-bio builder — Cloudflare + PostHog only.",
  "license": "MIT",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:brands": "turbo run build:brands",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check:licenses": "node scripts/check-licenses.mjs",
    "verify": "bun run check:licenses && bun run lint && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
